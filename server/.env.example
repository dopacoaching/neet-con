NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/neetcon2026

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Bootstrap admin login(s) — "email:password" pairs (comma-separated for more).
# Logs in as full "admin" role without seeding the DB. Keep secret.
ADMIN_CREDENTIALS=admin@example.com:change_this_password

# HDFC SmartGateway (powered by Juspay)
# Values come from your SmartGateway merchant dashboard. Until configured, the
# payment flow runs in MOCK mode (see HDFC_MOCK below). NEVER commit real values.
HDFC_API_KEY=your_api_key                 # Dashboard > Settings > API Keys
HDFC_MERCHANT_ID=your_merchant_id         # Account profile / merchant id
HDFC_RESPONSE_KEY=your_response_key       # Dashboard > Settings > Security > Response Key (HMAC)
HDFC_PAYMENT_PAGE_CLIENT_ID=your_payment_page_client_id   # often same as merchant id
# Base URL: sandbox vs production. Confirm against your integration doc.
#   Sandbox:    https://smartgatewayuat.hdfcbank.com
#   Production: https://smartgateway.hdfcbank.com
HDFC_BASE_URL=https://smartgatewayuat.hdfcbank.com
HDFC_API_VERSION=2023-06-30
HDFC_REDIRECT_URL=http://localhost:5000/api/payment/callback
HDFC_WEBHOOK_URL=http://localhost:5000/api/payment/webhook

# When true, payment is simulated locally (no real SmartGateway calls). Set to
# false once real credentials are configured above and validated in sandbox.
HDFC_MOCK=true

# App
CLIENT_URL=http://localhost:5173
REGISTRATION_FEE=100

# Event details shown in the confirmation message
EVENT_DATE=12 July 2026
EVENT_TIME=9:30 AM – 5:00 PM
EVENT_VENUE=Yamaniya Hall, Kuttikattor

# WhatsApp confirmation (Meta WhatsApp Cloud API) — PRIMARY delivery channel.
# Confirmation + entry QR are sent to the registrant's WhatsApp (mobileNumber).
# Requires an approved message template (UTILITY, image header + 7 body vars);
# see server/utils/whatsapp.js for the exact template spec.
#  - WHATSAPP_MOCK=true            -> simulate locally (no real send).
#  - false + creds below           -> real delivery via Meta Cloud API.
WHATSAPP_MOCK=true
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
# Webhook verification token — any random string you choose; paste the same
# value into Meta's app Webhooks config when setting the callback URL.
WHATSAPP_VERIFY_TOKEN=some_random_verify_string
WHATSAPP_TEMPLATE_NAME=neetcon_confirmation
WHATSAPP_TEMPLATE_LANG=en
WHATSAPP_COUNTRY_CODE=91
WHATSAPP_API_VERSION=v21.0
